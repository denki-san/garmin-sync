# Example garmin-sync profiles.toml
# Copy to ~/.config/garmin-sync/profiles.toml and edit.

[profiles.me]
email            = "you@example.com"
domain           = "garmin.com"                       # or "garmin.cn"
token_dir        = "~/.garminconnect-garmin_com"
output_dir       = "~/garmin-data/me"
password_env_var = "GARMIN_PASSWORD"

# A second account on the same machine (China region, separate password env var)
# [profiles.spouse]
# email            = "spouse@example.com"
# domain           = "garmin.cn"
# token_dir        = "~/.garminconnect-spouse-cn"
# output_dir       = "~/garmin-data/spouse"
# password_env_var = "SPOUSE_GARMIN_PASSWORD"
